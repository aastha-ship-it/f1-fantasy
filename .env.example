# Copy to .env.local and fill in the blanks for your local or production env.
# The values in this file are placeholders — never commit real secrets.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

INVITE_CODE=
CRON_SECRET=

# Optional: email of the admin to auto-bootstrap on every OAuth callback.
# Self-healing; makes `supabase db reset` + next sign-in re-grant admin.
ADMIN_EMAIL=

# Google OAuth (primary sign-in). Create an OAuth 2.0 Client ID in
# Google Cloud Console with authorized redirect URIs:
#   - http://127.0.0.1:54421/auth/v1/callback  (local Supabase)
#   - https://<project>.supabase.co/auth/v1/callback  (prod)
# Paste Client ID + Secret here. See CLAUDE.md for full setup steps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
